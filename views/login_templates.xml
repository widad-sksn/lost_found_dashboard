<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="custom_login_page" inherit_id="web.login">
            <xpath expr="." position="replace">
                <t t-call="web.layout">
                    <t t-set="html_data" t-value="{'style': 'height: 100%;'}"/>
                    <t t-set="head">
                        <t t-call-assets="web.assets_frontend" t-js="false"/>
                        <t t-call-assets="web.assets_frontend" t-css="false"/>
                    </t>
                    <body class="custom-login-body o_portal">
                        <div class="login-wrapper">
                            <div class="login-box">
                                <div class="login-left">
                                    <div class="glass-card">
                                        <h2 class="welcome-text">welcome</h2>
                                        <form class="oe_login_form custom-form" role="form" t-attf-action="/web/login{{ '?debug' if debug else '' }}" method="post" onsubmit="this.action = this.action + location.hash">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                            <div class="mb-3 field-login">
                                                <label for="login" class="form-label">NIM</label>
                                                <input type="text" placeholder="" name="login" t-att-value="login" id="login" t-attf-class="form-control" required="required" autofocus="autofocus" autocapitalize="off"/>
                                            </div>

                                            <div class="mb-3 field-password">
                                                <label for="password" class="form-label">Password</label>
                                                <input type="password" placeholder="" name="password" id="password" t-attf-class="form-control" required="required" autocomplete="current-password" t-att-autofocus="'autofocus' if login else None" maxlength="4096"/>
                                            </div>

                                            <div class="d-flex justify-content-between align-items-center mb-4 text-small mt-3">
                                                <div class="form-check mb-0">
                                                    <input class="form-check-input" type="checkbox" id="rememberMe"/>
                                                    <label class="form-check-label text-light" for="rememberMe" style="font-size: 0.8rem;">
                                                        Remember me
                                                    </label>
                                                </div>
                                                <a href="/web/reset_password" class="forgot-link text-light" style="font-size: 0.8rem; text-decoration: none;">Forgot password?</a>
                                            </div>

                                            <p class="alert alert-danger" t-if="error" role="alert">
                                                <t t-esc="error"/>
                                            </p>
                                            <p class="alert alert-success" t-if="message" role="status">
                                                <t t-esc="message"/>
                                            </p>

                                            <div class="text-center oe_login_buttons mt-4">
                                                <button type="submit" class="btn btn-primary btn-block btn-grad w-100">Log In</button>
                                                <t t-if="debug">
                                                    <button type="submit" name="redirect" value="/web/become" class="btn btn-link text-light btn-sm btn-block mt-2">Log in as superuser</button>
                                                </t>
                                            </div>
                                            
                                            <!-- Optional: Add Sign Up link if auth_signup is enabled -->
                                            <t t-if="signup_enabled">
                                                <div class="text-center mt-3">
                                                    <a href="/web/signup" class="text-light" style="font-size: 0.8rem; text-decoration: underline;">Belum punya akun? Daftar di sini</a>
                                                </div>
                                            </t>
                                        </form>
                                    </div>
                                </div>
                                <div class="login-right">
                                    <div class="purple-wave"></div>
                                    <!-- Menggunakan logo.png sesuai permintaan -->
                                    <img src="/lost_found_dashboard/static/src/img/logo.png" alt="Logo" class="wallet-icon"/>
                                </div>
                            </div>
                        </div>
                    </body>
                </t>
            </xpath>
        </template>
    </data>
</odoo>
