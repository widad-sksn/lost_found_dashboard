<odoo>
    <record id="found_item_action" model="ir.actions.act_window">
        <field name="name">Found Items</field>
        <field name="res_model">found.item</field>
        <field name="view_mode">kanban,tree,form,graph</field>
    </record>

    <record id="found_item_view_search" model="ir.ui.view">
        <field name="name">found.item.search</field>
        <field name="model">found.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="user_id"/>
                <filter string="Pending" name="filter_pending" domain="[('status', '=', 'draft')]"/>
                <filter string="Published" name="filter_published" domain="[('status', '=', 'approved')]"/>
                <filter string="Done" name="filter_done" domain="[('status', '=', 'done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="found_item_view_graph" model="ir.ui.view">
        <field name="name">found.item.graph</field>
        <field name="model">found.item</field>
        <field name="arch" type="xml">
            <graph string="Found Items Analysis" type="bar" sample="1">
                <field name="status" type="row"/>
            </graph>
        </field>
    </record>

    <record id="found_item_view_kanban" model="ir.ui.view">
            <field name="name">found.item.kanban</field>
            <field name="model">found.item</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" create="0">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="photo"/>

                    <field name="location"/>
                    <field name="date"/>
                    
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click d-flex align-items-center">
                                
                                <div class="o_kanban_image_container d-flex align-items-center justify-content-center"
                                    style="width: 120px; height: 120px; min-width: 120px; overflow: hidden; border-radius: 8px; border: 1px solid #dee2e6; margin-right: 15px;">
                                    <t t-if="record.photo.raw_value">
                                        <field name="photo" 
                                            widget="image" 
                                            options="{'preview_image': 'photo'}"
                                            style="width: 100%; height: 100%; object-fit: cover; display: block;"/>
                                    </t>
                                    <t t-if="!record.photo.raw_value">
                                        <span class="fa fa-camera fa-3x text-muted"/>
                                    </t>
                                </div>
                                
                                <div class="oe_kanban_details flex-grow-1">
                                    <strong class="o_kanban_record_title" style="font-size: 16px; font-weight: bold; margin-bottom: 6px; display: block;">
                                        <field name="name"/>
                                    </strong>
                                    

                                    <div class="text-muted" style="font-size: 13px;">
                                        <div><i class="fa fa-map-marker" style="margin-right: 5px;"/> <field name="location"/></div>
                                        <div><i class="fa fa-calendar" style="margin-right: 5px;"/> <field name="date"/></div>
                                    </div>
                                </div>
                                
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

    <record id="found_item_view_list" model="ir.ui.view">
        <field name="name">found.item.list</field>
        <field name="model">found.item</field>
        <field name="arch" type="xml">
            <tree create="0">
                <field name="ref_id"/>
                <field name="name"/>

                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="found_item_view_form" model="ir.ui.view">
        <field name="name">found.item.form</field>
        <field name="model">found.item</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Terima Laporan" class="oe_highlight" invisible="status != 'draft'" groups="lost_found_dashboard.group_lostnfound_staff"/>
                    <button name="action_reject" type="object" string="Tolak" invisible="status != 'draft'" groups="lost_found_dashboard.group_lostnfound_staff"/>
                    <button name="action_done" type="object" string="Tandai Selesai" class="oe_highlight" invisible="status != 'approved'" groups="lost_found_dashboard.group_lostnfound_staff"/>
                    
                    <field name="status" widget="statusbar" statusbar_visible="draft,approved,rejected,done" />
                </header>
                <sheet>
                    <group>
                        <field name="ref_id"/>
                        <field name="name"/>
                        <field name="user_id"/>
                        <field name="description"/>

                        <field name="location"/>
                        <field name="date"/>
                        <field name="photo" widget="image"/>
                    </group>
                    
                    <notebook>
                        <page string="Resolution Info">
                            <group>
                                <field name="status"/>
                                </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
