<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="lost_found_dashboard.ItemMatchingDashboard" owl="1">
        <div class="o_action_manager o_item_matching_dashboard w-100 h-100 d-flex flex-column flex-md-row" style="background-color: #0f111a;">
            
            <!-- Sidebar -->
            <div class="custom-sidebar d-flex flex-column text-white flex-shrink-0" style="background-color: #0B192C;">
                <div class="p-3 border-bottom border-light text-center" style="border-color: rgba(255,255,255,0.1) !important;">
                    <img src="/lost_found_dashboard/static/src/img/logo.png" alt="Logo" style="max-height: 60px; max-width: 100%; object-fit: contain;" />
                </div>
                
                <div class="sidebar-menu flex-grow-1 mt-3 px-2">
                    <a href="#" class="sidebar-link d-flex align-items-center py-3 px-3 rounded text-white text-decoration-none" t-on-click="() => this.navigateToAction('dashboard')">
                        <i class="fa fa-home me-3"></i> Portal Web
                    </a>
                    <a href="#" t-attf-class="sidebar-link d-flex align-items-center py-3 px-3 rounded text-white text-decoration-none {{ state.activeMenu === 'found' ? 'active' : '' }}" t-att-style="state.activeMenu === 'found' ? 'background-color: #1e3a8a;' : ''" t-on-click="() => this.navigateToAction('lost_found_dashboard.found_item_action')">
                        <i class="fa fa-file-text-o me-3"></i> Barang Ditemukan
                    </a>
                    <a href="#" t-attf-class="sidebar-link d-flex align-items-center py-3 px-3 rounded text-white text-decoration-none {{ state.activeMenu === 'lost' ? 'active' : '' }}" t-att-style="state.activeMenu === 'lost' ? 'background-color: #1e3a8a;' : ''" t-on-click="() => this.navigateToAction('lost_found_dashboard.lost_claim_action')">
                        <i class="fa fa-search me-3"></i> Data Barang Hilang
                    </a>
                    <a href="#" t-attf-class="sidebar-link d-flex align-items-center py-3 px-3 rounded text-white text-decoration-none {{ state.activeMenu === 'matching' ? 'active' : '' }}" t-att-style="state.activeMenu === 'matching' ? 'background-color: #1e3a8a;' : ''" t-on-click="() => this.navigateToAction('lost_found_dashboard.action_item_matching')">
                        <i class="fa fa-check-square-o me-3"></i> Pencocokan Barang
                    </a>
                    <a href="#" t-attf-class="sidebar-link d-flex align-items-center py-3 px-3 rounded text-white text-decoration-none {{ state.activeMenu === 'claims' ? 'active' : '' }}" t-att-style="state.activeMenu === 'claims' ? 'background-color: #1e3a8a;' : ''" t-on-click="() => this.navigateToAction('lost_found_dashboard.item_claim_request_action')">
                        <i class="fa fa-history me-3"></i> History Laporan
                    </a>
                </div>
                
                <div class="p-3 border-top border-light" style="border-color: rgba(255,255,255,0.1) !important;">
                    <a href="/web/session/logout" class="sidebar-link d-flex align-items-center py-2 px-3 rounded text-white-50 text-decoration-none hover-white">
                        <i class="fa fa-sign-out me-3"></i> Log Out
                    </a>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="flex-grow-1 d-flex flex-column h-100 overflow-hidden" style="background-color: #0f111a;">
                <div class="top-header p-4 d-flex justify-content-between align-items-center z-index-1" style="background-color: rgba(11, 25, 44, 0.95); border-bottom: 1px solid rgba(255,255,255,0.05); z-index: 10;">
                    <div>
                        <h2 class="m-0 font-weight-bold text-white">
                            <t t-if="state.activeMenu === 'matching'">Pencocokan Barang</t>
                            <t t-if="state.activeMenu === 'found'">Barang Ditemukan</t>
                            <t t-if="state.activeMenu === 'lost'">Data Barang Hilang</t>
                            <t t-if="state.activeMenu === 'claims'">History Laporan</t>
                        </h2>
                        <p class="text-white-50 m-0 small">Sistem Hilang Temu Terpadu</p>
                    </div>
                    <div class="d-flex align-items-center text-white">
                        <i class="fa fa-bell-o fa-lg me-4 text-white-50"></i>
                        <div class="d-flex align-items-center">
                            <i class="fa fa-user-circle fa-2x me-2 text-white-50"></i>
                            <span class="font-weight-bold"><t t-out="state.userName"/></span>
                        </div>
                    </div>
                </div>

                <!-- Dynamic Content Container -->
                <div class="dashboard-content flex-grow-1 overflow-auto position-relative">
                    <t t-if="state.activeMenu === 'matching'">
                        <!-- Matches Dashboard Content -->
                        <div class="p-4 d-flex flex-column align-items-center mt-3">
                            <t t-if="state.matches.length > 0">
                                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3 w-100 p-2" style="max-width: 1400px;">
                                    <t t-foreach="state.matches" t-as="match" t-key="match.claim_id">
                                        <div class="col">
                                            <div class="card h-100 shadow-sm border-0 rounded-3" style="background-color: #1a1f36 !important; border: 1px solid rgba(255,255,255,0.1) !important; cursor: pointer; transition: transform 0.2s;" t-on-click="() => this.openMatchDetail(match)">
                                                <div class="d-flex justify-content-center align-items-center p-2" style="height: 140px; background-color: #0f111a; border-radius: 8px 8px 0 0;">
                                                    <t t-if="match.original_photo">
                                                        <img t-attf-src="data:image/png;base64,{{match.original_photo}}" style="max-height: 100%; max-width: 100%; object-fit: contain;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <i class="fa fa-image fa-3x text-secondary"></i>
                                                    </t>
                                                </div>
                                                <div class="card-body p-3 border-top d-flex flex-column" style="border-color: rgba(255,255,255,0.1) !important; background-color: #1a1f36 !important; color: white !important;">
                                                    <h6 class="card-title text-truncate mb-1 text-white" style="font-size: 14px;" t-out="match.original_name"/>
                                                    <p class="card-text mb-2" style="font-size: 11px; color: #94a3b8 !important;"><i class="fa fa-user me-1"/>Klaim: <strong class="text-white" t-out="match.claim_user"/></p>
                                                    <p class="card-text text-warning mb-2" style="font-size: 11px;" t-out="match.item_type"/>
                                                    <span class="badge w-100 py-2 mt-auto" style="background-color: rgba(255,255,255,0.1); color: #f1f5f9; border: 1px solid rgba(255,255,255,0.2);">Cek Detail <i class="fa fa-arrow-right ms-1"/></span>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>

                                <!-- Custom Match Detail Modal Overlay -->
                                <t t-if="state.selectedMatch">
                                    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center" style="background-color: rgba(0,0,0,0.85); z-index: 1050; backdrop-filter: blur(4px);">
                                        <div class="rounded-3 shadow-lg d-flex flex-column" style="background-color: #1a1f36; width: 95%; max-width: 1100px; max-height: 90vh; border: 1px solid rgba(255,255,255,0.2);">
                                            
                                            <div class="d-flex justify-content-between align-items-center p-3" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                                                <h5 class="text-white mb-0"><i class="fa fa-balance-scale me-2"/>Verifikasi Klaim</h5>
                                                <button type="button" class="btn-close btn-close-white" t-on-click="closeMatchDetail"></button>
                                            </div>

                                            <div class="p-4 overflow-auto flex-grow-1" style="background-color: #0f111a;">
                                                <t t-set="currentMatch" t-value="state.selectedMatch"/>
                                                <div class="row w-100 justify-content-center m-0">
                                                    
                                                    <!-- Left Card: Original Item -->
                                                    <div class="col-12 col-md-6 d-flex justify-content-center mb-3">
                                                        <div class="item-card bg-dark text-white shadow-lg border-0 rounded-3 w-100" style="border: 1px solid rgba(255,255,255,0.2) !important;">
                                                            <div class="p-3">
                                                                <h6 class="text-center font-weight-bold mb-3 text-info"><i class="fa fa-cube me-2"/>Barang Asli</h6>
                                                                <div class="text-center mb-3">
                                                                    <t t-if="currentMatch.original_photo">
                                                                        <img t-attf-src="data:image/png;base64,{{currentMatch.original_photo}}" class="item-img rounded" style="box-shadow: 0 4px 10px rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); width: 100%; height: 220px; object-fit: contain; background-color: #000;"/>
                                                                    </t>
                                                                    <t t-else="">
                                                                        <div class="item-img-placeholder rounded d-flex align-items-center justify-content-center" style="background-color: #0f111a; border: 2px dashed rgba(255,255,255,0.2); width: 100%; height: 220px;">
                                                                            <i class="fa fa-image fa-2x" style="color: #64748b;"></i>
                                                                        </div>
                                                                    </t>
                                                                </div>
                                                                <div class="item-details" style="font-size: 14px;">
                                                                    <p class="mb-1"><span style="color: #94a3b8; width: 90px; display: inline-block;">Tipe:</span><strong class="text-white" t-out="currentMatch.item_type"/></p>
                                                                    <p class="mb-1"><span style="color: #94a3b8; width: 90px; display: inline-block;">Nama:</span><strong class="text-white" t-out="currentMatch.original_name"/></p>
                                                                    <p class="mb-1"><span style="color: #94a3b8; width: 90px; display: inline-block;">Tags:</span><span class="text-warning" t-out="currentMatch.original_category"/></p>
                                                                    <p class="mb-1"><span style="color: #94a3b8; width: 90px; display: inline-block;">Lokasi:</span><span class="text-info" t-out="currentMatch.original_location"/></p>
                                                                    <p class="mb-1"><span style="color: #94a3b8; width: 90px; display: inline-block;">Tanggal:</span><span class="text-white" t-out="currentMatch.original_date"/></p>
                                                                    <p class="mb-1"><span style="color: #94a3b8; width: 90px; display: inline-block;">Pelapor:</span><span class="text-white" t-out="currentMatch.original_reporter"/></p>
                                                                    <div class="mt-2 p-2 rounded" style="background-color: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05);">
                                                                        <span style="color: #94a3b8; display: block; margin-bottom: 2px;">Deskripsi Asli:</span>
                                                                        <span style="color: #f1f5f9; font-size: 13px;" t-out="currentMatch.original_description"/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Right Card: Claim Item -->
                                                    <div class="col-12 col-md-6 d-flex justify-content-center mb-3">
                                                        <div class="item-card bg-dark text-white shadow-lg border-0 rounded-3 w-100" style="border: 1px solid rgba(255,255,255,0.2) !important;">
                                                            <div class="p-3">
                                                                <h6 class="text-center font-weight-bold mb-3 text-warning"><i class="fa fa-user me-2"/>Data Klaim Pengguna</h6>
                                                                <div class="text-center mb-3">
                                                                    <t t-if="currentMatch.claim_photo">
                                                                        <img t-attf-src="data:image/png;base64,{{currentMatch.claim_photo}}" class="item-img rounded" style="box-shadow: 0 4px 10px rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); width: 100%; height: 220px; object-fit: contain; background-color: #000;"/>
                                                                    </t>
                                                                    <t t-else="">
                                                                        <div class="item-img-placeholder rounded d-flex align-items-center justify-content-center" style="background-color: #0f111a; border: 2px dashed rgba(255,255,255,0.2); width: 100%; height: 220px;">
                                                                            <i class="fa fa-image fa-2x" style="color: #64748b;"></i>
                                                                        </div>
                                                                    </t>
                                                                </div>
                                                                <div class="item-details" style="font-size: 14px;">
                                                                    <p class="mb-1"><span style="color: #94a3b8; width: 90px; display: inline-block;">Pengklaim:</span><strong class="text-white" t-out="currentMatch.claim_user"/></p>
                                                                    <p class="mb-1"><span style="color: #94a3b8; width: 90px; display: inline-block;">Tanggal:</span><span class="text-white" t-out="currentMatch.claim_date"/></p>
                                                                    <div class="mt-2 p-2 rounded" style="background-color: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05);">
                                                                        <span style="color: #94a3b8; display: block; margin-bottom: 2px;">Keterangan / Bukti:</span>
                                                                        <span style="color: #f1f5f9; font-size: 13px;" t-out="currentMatch.claim_proof_description"/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-center p-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
                                                <button class="btn btn-success px-5 py-2 font-weight-bold text-white shadow-sm" t-on-click="onMatchClick" t-att-disabled="state.loading" style="border: none; font-size: 15px;"><i class="fa fa-check me-2"/> Cocok / Selesai</button>
                                                <button class="btn btn-outline-light px-5 py-2 font-weight-bold ms-3" t-on-click="onSkipClick" t-att-disabled="state.loading" style="font-size: 15px;"><i class="fa fa-times me-2"/> Tolak Klaim</button>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="alert alert-dark mt-5 border-light" role="alert" style="background-color: rgba(255,255,255,0.05); color: white;">
                                    Tidak ada data barang yang tersedia untuk dicocokkan.
                                </div>
                                <button class="btn btn-primary" t-on-click="fetchMatches" style="background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%); border: none;">Muat Ulang</button>
                            </t>
                        </div>
                        
                        <!-- Modal for Image Preview -->
                        <div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered modal-lg">
                                <div class="modal-content bg-transparent border-0">
                                    <div class="modal-header border-0 pb-0 justify-content-end">
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body text-center pt-0">
                                        <t t-if="state.modalImage">
                                            <img t-attf-src="data:image/png;base64,{{state.modalImage}}" class="img-fluid rounded shadow-lg" style="max-height: 80vh;"/>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                    <t t-else="">
                        <!-- Odoo Standard View Embedding -->
                        <!-- Dark background wrap for lists -->
                        <div class="h-100" style="background-color: #0f111a; border-radius: 8px; margin: 15px; border: 1px solid rgba(255,255,255,0.1); overflow: hidden; display: flex; flex-direction: column;">
                            <div style="background-color: #1a1f36; padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <h6 class="text-white mb-0 ms-2"><i class="fa fa-list me-2"/>Manajemen Data</h6>
                            </div>
                            <!-- Embed the native Odoo view -->
                            <div class="flex-grow-1 odoo-view-container dark-mode-odoo-view" style="background-color: #1a1f36;">
                                <View t-props="viewProps" t-key="state.activeMenu" />
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
