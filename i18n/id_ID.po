#. module: lost_found_dashboard
#: model:mail.template,body_html:lost_found_dashboard.email_template_finder_matched
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                        Halo <t t-out=\"object.found_item_id.user_id.name or 'Penemu'\"></t>,<br><br>\n"
"                        Barang yang Anda laporkan (<strong><t t-out=\"object.found_item_id.name\"></t></strong>) telah berhasil diklaim dan diverifikasi oleh pemilik aslinya!<br>\n"
"                        Terima kasih atas kebaikan dan kejujuran Anda membantu sesama.<br><br>\n"
"                        Salam hangat,<br>Tim Smart Lost &amp; Found<br>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""

#. module: lost_found_dashboard
#: model:mail.template,body_html:lost_found_dashboard.email_template_loser_matched
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                        Halo <t t-out=\"object.lost_claim_id.person_name or 'Warga Kampus'\"></t>,<br><br>\n"
"                        <strong>Kabar Gembira!</strong> Klaim dari penemu atas barang hilang Anda (<strong><t t-out=\"object.lost_claim_id.name\"></t></strong>) telah diverifikasi dan disetujui!<br>\n"
"                        Silakan segera kunjungi pos keamanan atau pusat layanan kampus dengan membawa identitas Anda untuk mengambil barang tersebut.<br><br>\n"
"                        Terima kasih telah menggunakan layanan Smart Lost &amp; Found!<br>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""

#. module: lost_found_dashboard
#: model:mail.template,body_html:lost_found_dashboard.email_template_lost_claim_matched
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                        Halo <t t-out=\"object.person_name or 'Warga Kampus'\"></t>,<br><br>\n"
"                        <strong>Kabar Gembira!</strong> Sistem kami mendeteksi bahwa barang Anda yang hilang (<strong><t t-out=\"object.name\"></t></strong>) kemungkinan besar telah ditemukan!<br>\n"
"                        Barang tersebut dilaporkan ditemukan di sekitar: <strong><t t-out=\"object.matched_item_location\"></t></strong>.<br><br>\n"
"                        Silakan segera kunjungi pos keamanan atau pusat layanan kampus dengan membawa identitas Anda untuk memverifikasi dan mengambil barang tersebut.<br><br>\n"
"                        Terima kasih telah menggunakan layanan Smart Lost &amp; Found!<br>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""

